"""
title: Reasoning Effort Selector
id: reasoning_effort_toggle
description: Toggle reasoning on/off and select effort level (low/medium/high) from the chat
author: you
license: MIT
version: 2.0.0
"""
from pydantic import BaseModel, Field
from typing import Optional

class Filter:
    class Valves(BaseModel):
        pass

    class UserValves(BaseModel):
        reasoning_effort: str = Field(
            default="medium",
            description="Reasoning effort level (only applies when toggle is ON)",
            json_schema_extra={
                "input": {
                    "type": "select",
                    "options": [
                        {"value": "low", "label": "Low — Faster, less reasoning"},
                        {"value": "medium", "label": "Medium — Balanced"},
                        {"value": "high", "label": "High — Deep reasoning, slower"}
                    ]
                }
            }
        )

    def __init__(self):
        self.valves = self.Valves()
        self.toggle = True
        self.icon = "data:image/svg+xml;base64,"

    async def inlet(self, body: dict, __user__: Optional[dict] = None) -> dict:
        # Get the user's selected effort level from UserValves
        user_valves = __user__.get("valves") if __user__ else None
        if user_valves and hasattr(user_valves, "reasoning_effort"):
            effort = user_valves.reasoning_effort
        else:
            effort = "medium"  # fallback

        # Inject reasoning_effort into the request body
        body["reasoning_effort"] = effort
        return body
